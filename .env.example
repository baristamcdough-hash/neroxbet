# Server Configuration
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/neroxbet

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h

# Flutterwave (M-Pesa integration)
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# Kassify (MTN MoMo integration)
KASSIFY_API_KEY=your-kassify-api-key
KASSIFY_SECRET_KEY=your-kassify-secret-key
KASSIFY_BASE_URL=https://api.kassify.com/v1

# Cryptomus (Crypto payments)
CRYPTOMUS_API_KEY=your-cryptomus-api-key
CRYPTOMUS_MERCHANT_ID=your-cryptomus-merchant-id
CRYPTOMUS_BASE_URL=https://api.cryptomus.com/v1
